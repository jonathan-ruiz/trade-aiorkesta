# Orchestrator Configuration Example
# Copy to .env and fill in actual values

# Event Loop
LOOP_INTERVAL_MS=300000
ORCHESTRATOR_ENABLED=true

# System State
SYSTEM_STATE=PAPER_TRADING
TRADING_MODE=PAPER
RISK_ACKNOWLEDGED=false

# Health Checks
HEALTH_CHECK_INTERVAL_MS=60000

# Circuit Breaker
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_FAILURES=5
CIRCUIT_BREAKER_SUCCESSES=2
CIRCUIT_BREAKER_TIMEOUT=60000

# eToro API
ETORO_API_URL=https://api-portal.etoro.com
ETORO_API_KEY=your_api_key_here
ETORO_API_SECRET=your_api_secret_here
ETORO_PAPER_TRADING=true

# Database (Audit Log)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trade_aiorkesta
DB_USER=postgres
DB_PASSWORD=your_db_password_here
