# Environment variables for trade.aiorkesta.com
# Copy to .env and fill in actual values (NEVER commit .env to git)

NODE_ENV=production

# eToro API configuration
ETORO_API_URL=https://api-portal.etoro.com
ETORO_API_KEY=your_demo_key_here

# Security
SESSION_SECRET=generate_a_random_string_here

# Feature flags
PAPER_TRADING_MODE=true
ENABLE_AI_DECISIONS=false

# Limits
MAX_DAILY_LOSS_USD=100
MAX_POSITION_SIZE_USD=500

# Logging
LOG_LEVEL=info
